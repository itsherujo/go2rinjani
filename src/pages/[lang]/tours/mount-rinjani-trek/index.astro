---
export const prerender = true;
import MountRinjaniTrekPage from '../../../../features/mount-rinjani-trek/Page.astro';

export function getStaticPaths() {
  const langs = ["id", "zh", "de", "fr", "es"];
  return langs.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
---

<MountRinjaniTrekPage lang={lang as string} />
