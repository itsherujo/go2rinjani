---
import "../styles/global.css";
import { Font } from "astro:assets";
import LegalPageIsland from "../features/legal/islands/LegalPageIsland";
import SEOHead from "../components/seo/SEOHead.astro";
import SchemaOrg from "../components/seo/SchemaOrg.astro";
import type { Lang } from "../i18n/config";
import { getLangFromUrl } from "../i18n/utils";
import { getCanonicalUrl } from "../utils/seo";
import {
  buildBreadcrumbSchema,
  buildOrganizationSchema,
  buildWebPageSchema,
  buildWebSiteSchema,
} from "../utils/schema";

interface Props {
  title?: string;
  description?: string;
  section?: string;
  articleTitle?: string;
  currentSlug?: string;
  lang?: string;
}

const {
  title,
  description,
  section,
  articleTitle,
  currentSlug,
  lang: langProp,
} = Astro.props;

const lang = (langProp ?? getLangFromUrl(Astro.url)) as Lang;
const pageTitle = title ? `${title} | Go2Rinjani` : "Legal | Go2Rinjani";
const pageDescription =
  description || "Legal documents and policies for Go2Rinjani.";

const legalPath = currentSlug ? `/legal/${currentSlug}` : "/legal";
const pageUrl = getCanonicalUrl(Astro.site, legalPath, lang);
const homeUrl = getCanonicalUrl(Astro.site, "/", lang);

const schemas = [
  buildOrganizationSchema(),
  buildWebSiteSchema(),
  buildWebPageSchema({
    name: pageTitle,
    description: pageDescription,
    url: pageUrl,
  }),
  buildBreadcrumbSchema([
    { name: "Home", url: homeUrl },
    { name: section ?? "Legal", url: homeUrl },
    { name: articleTitle ?? title ?? "Legal", url: pageUrl },
  ]),
];
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <SEOHead
      title={pageTitle}
      description={pageDescription}
      lang={lang}
      pathname={legalPath}
    />
    <Font cssVariable="--font-inter" preload />
    <SchemaOrg schema={schemas} />

    <style is:inline>
      :root {
        --font-scale: 1;
      }
    </style>
  </head>
  <body
    class="bg-bg-light/20 text-black/80 antialiased font-sans"
    style={`font-size: calc(1rem * var(--font-scale)); line-height: 180%;`}
  >
    <LegalPageIsland
      client:load
      section={section}
      title={articleTitle}
      currentSlug={currentSlug}
      lang={lang}
    >
      <slot />
    </LegalPageIsland>
  </body>
</html>
