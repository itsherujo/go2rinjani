---
import "../styles/global.css";
import SEOHead from "../components/seo/SEOHead.astro";
import SchemaOrg from "../components/seo/SchemaOrg.astro";
import BookingFormIsland, {
  type BookingFormTranslations,
} from "../components/shared/BookingFormIsland";
import PaymentHeader from "../features/payment/components/PaymentHeader.astro";
import type { Lang } from "../i18n/config";
import { getCanonicalUrl } from "../utils/seo";
import {
  buildOrganizationSchema,
  buildWebPageSchema,
  buildWebSiteSchema,
} from "../utils/schema";

interface Props {
  lang: Lang;
  title: string;
  description: string;
  bookingTranslations: BookingFormTranslations;
}

const { lang, title, description, bookingTranslations } = Astro.props;

const paymentPath =
  lang === "en" ? "/payment-information" : `/${lang}/payment-information`;

const pageUrl = getCanonicalUrl(Astro.site, paymentPath, lang);

const schemas = [
  buildOrganizationSchema(),
  buildWebSiteSchema(),
  buildWebPageSchema({
    name: title,
    description,
    url: pageUrl,
  }),
];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <SEOHead
      title={title}
      description={description}
      lang={lang}
      pathname={paymentPath}
    />
    <SchemaOrg schema={schemas} />
  </head>
  <body
    class="min-h-screen bg-background text-foreground antialiased font-sans selection:bg-black selection:text-white"
  >
    <PaymentHeader />
    <slot />
    <BookingFormIsland client:idle translations={bookingTranslations} />
  </body>
</html>
