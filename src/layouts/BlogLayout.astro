---
import BaseLayout from "./BaseLayout.astro";
import BlogHeroImageIsland from "../components/shared/BlogHeroImageIsland";
import { getLangFromUrl } from "../i18n/utils";
import {
  getCanonicalUrl,
  parseBlogDate,
  toAbsoluteUrl,
} from "../utils/seo";
import {
  buildArticleSchema,
  buildBreadcrumbSchema,
} from "../utils/schema";

interface Props {
  title?: string;
  description?: string;
  category?: string;
  date?: string;
  location?: string;
  image?: string;
  slug?: string;
}

const {
  title,
  description,
  category,
  date,
  location,
  image,
  slug = "",
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
const heroImage =
  image ||
  "https://cdn.sanity.io/images/8tpq0e4r/production/b257f7ff58d72e08be98d5e033d5a9c718ebfc05-2667x4000.jpg?w=1920&q=60&auto=format";

const blogPath =
  lang === "en" ? `/blog/${slug}` : `/${lang}/blog/${slug}`;
const pageUrl = getCanonicalUrl(Astro.site, blogPath, lang as any);
const imageUrl = toAbsoluteUrl(Astro.site, heroImage);
const datePublished = date ? parseBlogDate(date) : new Date().toISOString().split("T")[0]!;

const schemas = [
  buildArticleSchema({
    title: title ?? "Blog",
    description: description ?? "",
    url: pageUrl,
    image: imageUrl,
    datePublished,
  }),
  buildBreadcrumbSchema([
    { name: "Home", url: getCanonicalUrl(Astro.site, "/", lang as any) },
    {
      name: "Blog",
      url: getCanonicalUrl(Astro.site, lang === "en" ? "/blog" : `/${lang}/blog`, lang as any),
    },
    { name: title ?? "Article", url: pageUrl },
  ]),
];
---

<BaseLayout
  title={title}
  description={description}
  pathname={blogPath}
  ogImage={imageUrl}
  ogType="article"
  schemas={schemas}
>
  <div class="blog-container">
    <main class="paddingBottom1">
      <div class="page_box__lvt9Q paddingRight5 paddingLeft5">
        <div class="infoBox_box__k7Pde">
          <div class="infoBox_containerTrans__qCtga infoBox_container____Qkf paddingTop5 paddingBottom4">
            <div>
              <div class="infoBox_content__JD0Go">
                <div style="width: 100%;" class="infoBox_title__AgwO8 paddingRight2 fontSize1">
                  {title}
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="page_head__6ru0R fontSize6 paddingRight5 paddingLeft5 marginTop3 marginBottom5">
        <div class="page_category__Kw1vH page_headCol__szlFi">{category || "Category"}</div>
        <div class="page_date__4mCAF page_headCol__szlFi">{date || "Date"}</div>
        <div class="page_location__Jtgyg page_headCol__szlFi">
          {location || "Location"}
        </div>
        <div class="page_address__ZjUy9 page_headCol__szlFi">Go2Rinjani Guide</div>
      </div>

      <div>
        <div class="listGallery_gallery__5cY7_ marginTop7 paddingRight7 paddingLeft7">
          <div class="listGallery_item__lYf_P paddingRight7 paddingLeft7">
            <div class="listGallery_imageContainer__n3YNM">
              <BlogHeroImageIsland client:visible highResUrl={heroImage} />
            </div>
          </div>
        </div>
      </div>

      <div class="page_content__kRXq7">
        <div class="marginTop2 paddingBottom6">
          <div class="page_text__ym3Et fontSize4">
            <div class="paddingRight3 markdown-content">
              <slot />
            </div>
          </div>
          <div></div>
        </div>
      </div>
    </main>
  </div>
</BaseLayout>

