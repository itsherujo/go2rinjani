---
import AnimatedArrowIsland from "./AnimatedArrowIsland";

interface BookingData {
  duration?: string;
  route?: string;
  packageName?: string;
  hideOptions?: boolean;
}

interface Props {
  title: string;
  subtitle?: string;
  desc: string;
  ctaLabel: string;
  ctaHref?: string;
  secondaryCtaLabel?: string;
  secondaryCtaHref?: string;
  bgColorClass?: string;
  bgColorHex?: string;
  className?: string;
  bookingData?: BookingData;
}

const {
  title,
  subtitle,
  desc,
  ctaLabel,
  ctaHref,
  secondaryCtaLabel,
  secondaryCtaHref,
  bgColorClass = "bg-brand-blue",
  bgColorHex,
  className = "pb-8 lg:pb-16 pt-4 lg:pt-8",
  bookingData,
} = Astro.props;

const isBookingTrigger = ctaHref === "#book";
const wrapperStyle = bgColorHex ? `background-color: ${bgColorHex}` : "";
const wrapperClass = `w-full px-4 lg:px-6 py-4 lg:py-6 flex flex-col ${bgColorHex ? "" : bgColorClass}`;
---

<section class={`w-full px-4 xl:px-5 py-8 ${className}`}>
  <div class={wrapperClass} style={wrapperStyle}>
    <div class="w-full max-w-4xl">
      {subtitle && (
        <h3 class="text-sm md:text-base tracking-widest uppercase mb-6 font-medium text-foreground/70">
          {subtitle}
        </h3>
      )}
      <h2 class="text-[2rem] leading-[1.05] min-[481px]:text-4xl lg:text-[4.5rem] lg:leading-[1.1] font-medium tracking-tight text-foreground mb-4 lg:mb-5">
        {title}
      </h2>
      <p class="text-base min-[481px]:text-lg lg:text-[1.7rem] font-light text-foreground max-w-full lg:max-w-[95%] leading-snug lg:leading-tight mb-8 min-[481px]:mb-12 lg:mb-7">
        {desc}
      </p>
      <div class="flex flex-col md:flex-row gap-4 w-full">
        <div class="w-full md:w-[400px]">
          <AnimatedArrowIsland
            client:visible
            text={ctaLabel}
            href={isBookingTrigger ? undefined : ctaHref}
            isBookingTrigger={isBookingTrigger}
            bookingData={bookingData}
            hideBorders={true}
            textClassName="text-xs lg:text-[13px] font-medium uppercase"
            paddingClassName="py-0 lg:py-[11px]"
          />
        </div>
        {secondaryCtaLabel && secondaryCtaHref && (
          <div class="w-full md:w-[400px]">
            <AnimatedArrowIsland
              client:visible
              text={secondaryCtaLabel}
              href={secondaryCtaHref}
              hideBorders={true}
              textClassName="text-xs lg:text-[13px] font-medium uppercase"
              paddingClassName="py-0 lg:py-[11px]"
            />
          </div>
        )}
      </div>
    </div>
  </div>
</section>
