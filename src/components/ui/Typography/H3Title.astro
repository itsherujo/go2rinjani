---
import { cn } from "../../../lib/utils";

interface Props extends astroHTML.JSX.HTMLAttributes {
  class?: string;
}

const { class: className = "", ...props } = Astro.props;
---

<h3
  class={cn("text-xl md:text-2xl font-medium tracking-tight text-foreground", className)}
  {...props}
>
  <slot />
</h3>
