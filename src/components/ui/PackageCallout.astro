---
import AnimatedArrowIsland from "./AnimatedArrowIsland";
import Section from "./Layout/Section.astro";
import HeroTitle from "./Typography/HeroTitle.astro";
import HeroDesc from "./Typography/HeroDesc.astro";

interface Props {
  id?: string;
  sectionTitle?: string;
  title: string;
  desc: string;
  ctaLabel: string;
  ctaUrl: string;
  images: any[];
  layoutCols: string;
  bgColor?: string;
}

const {
  sectionTitle,
  title,
  desc,
  ctaLabel,
  ctaUrl,
  images,
  layoutCols,
  bgColor = "bg-brand-teal",
} = Astro.props;
---

<Section class="py-0 mb-10 min-[481px]:mb-12 lg:mb-16">
  <div class={`w-full flex flex-col ${bgColor}`}>
    {/* Text Container */}
    <div
      class="w-full px-4 min-[481px]:px-5 py-4 min-[481px]:py-5 flex flex-col"
    >
      {
        sectionTitle && (
          <span class="text-xs lg:text-lg font-medium tracking-[0.13em] uppercase text-foreground mb-4 md:mb-6 block">
            {sectionTitle}
          </span>
        )
      }
      <HeroTitle as="h2" class="mb-4 md:mb-6">{title}</HeroTitle>
      <HeroDesc class="mb-6">{desc}</HeroDesc>
      <div class="w-fit mt-auto md:w-[350px]">
        <AnimatedArrowIsland
          client:visible
          text={ctaLabel}
          href={ctaUrl}
          hideBorders={true}
          textClassName="text-[11px] lg:text-[13px] tracking-widest uppercase font-semibold"
          paddingClassName="py-1"
        />
      </div>
    </div>

    {/* Images Container - Flush left, right, and bottom */}
    <div class="w-full">
      {/* Desktop/Tablet Layout grid */}
      <div
        class="hidden min-[481px]:grid gap-2 lg:gap-4 h-[35vh] lg:h-[60vh] w-full"
        style={`grid-template-columns: ${layoutCols}`}
      >
        {
          images.map((img, index) => {
            const isObj = typeof img === 'object';
            const src = isObj ? img.src : img;
            const width = isObj ? img.width : undefined;
            const height = isObj ? img.height : undefined;
            const altText = isObj && img.alt ? img.alt : `${title} gallery image ${index + 1}`;
            return (
              <div class="bg-gray-100 overflow-hidden h-full w-full">
                <img src={src} width={width} height={height} class="w-full h-full object-cover" alt={altText} loading="lazy" />
              </div>
            );
          })
        }
      </div>

      {/* Mobile Layout Horizontal Scroll */}
      <div
        class="flex min-[481px]:hidden overflow-x-auto snap-x snap-mandatory gap-2 w-full [&::-webkit-scrollbar]:hidden [-ms-overflow-style:none] scrollbar-none"
      >
        {
          images.map((img, index) => {
            const isObj = typeof img === 'object';
            const src = isObj ? img.src : img;
            const width = isObj ? img.width : undefined;
            const height = isObj ? img.height : undefined;
            const altText = isObj && img.alt ? img.alt : `${title} gallery image ${index + 1}`;
            return (
              <div class="w-[85vw] shrink-0 h-[45vh] snap-start bg-gray-100 overflow-hidden">
                <img src={src} width={width} height={height} class="w-full h-full object-cover" alt={altText} loading="lazy" />
              </div>
            );
          })
        }
        {/* Spacer for a neat finish at the end of scroll on mobile */}
        <div class="w-px shrink-0"></div>
      </div>
    </div>
  </div>
</Section>
