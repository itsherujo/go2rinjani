---
import testimonials from '../../data/testimonials.json';
import googleLogo from '@/assets/review/google/google-logo.svg';
import googleVerifiedBadge from '@/assets/review/google/google-verified-badge.svg';
import tripadvisorLogo from '@/assets/review/tripadvisor/tripadvisor-logo.svg';
import tripadvisorVerifiedBadge from '@/assets/review/tripadvisor/tripadvisor-verified-badge.svg';

const avatars = import.meta.glob<{ default: ImageMetadata }>('/src/assets/review/**/*.{jpeg,jpg,png,gif,avif}', { eager: true });

const getAvatarSrc = (imagePath: string) => {
  if (!imagePath) return "https://cdn.prod.website-files.com/6350808bc45bd0c902af10e6/67572f6d09dc73acabbf029a_testimonial-jobbatical.png";
  if (imagePath.startsWith('/assets/review/')) {
    const localPath = '/src' + imagePath;
    return avatars[localPath]?.default?.src || imagePath;
  }
  return imagePath;
};

// Divide testimonials into 3 columns
const col1 = testimonials.slice(0, 16);
const col2 = testimonials.slice(16, 32);
const col3 = testimonials.slice(32, 48);

// Helper function to render stars (since Astro maps perfectly like JSX)
const renderStars = (t: any, idx: number) => {
  return Array.from({ length: 5 }).map((_, i) => {
    const rating = t.rating || 5;
    const isFull = i < Math.floor(rating);
    const isHalf = !isFull && i < rating;

    if (t.source === 'google') {
      if (isFull) {
        return `<svg class="w-4 h-4 text-yellow-400 fill-current" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" /></svg>`;
      } else if (isHalf) {
        return `<svg class="w-4 h-4" viewBox="0 0 24 24"><defs><linearGradient id="half-${idx}-${i}" x1="0" x2="1" y1="0" y2="0"><stop offset="50%" stop-color="#facc15" /><stop offset="50%" stop-color="#e5e7eb" /></linearGradient></defs><path fill="url(#half-${idx}-${i})" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" /></svg>`;
      } else {
        return `<svg class="w-4 h-4 text-gray-200 fill-current" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" /></svg>`;
      }
    } else {
      if (isFull) {
        return `<div class="w-3.5 h-3.5 rounded-full bg-[#00852f]"></div>`;
      } else if (isHalf) {
        return `<div class="w-3.5 h-3.5 rounded-full border-[1.5px] border-[#00852f] overflow-hidden flex"><div class="w-[50%] h-full bg-[#00852f]"></div></div>`;
      } else {
        return `<div class="w-3.5 h-3.5 rounded-full border-[1.5px] border-[#00852f]"></div>`;
      }
    }
  }).join('');
};

