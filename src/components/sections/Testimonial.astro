<script>
  function initTestimonial() {
    const gridParent = document.getElementById("testimonial-grid");
    if (!gridParent) return;

    const baseSpeed = 0.25;
    const mobileMultiplier = 2;
    const breakpoint = 992;

    const allStripes = gridParent.querySelectorAll(".am-customers-wall-of-love-stripe");
    const stripes: any[] = [];
    let animationFrameId: number;

    const resizeListener = () => {
      const isMobile = window.innerWidth < breakpoint;
      stripes.forEach((stripe) => {
        const newBase = isMobile ? baseSpeed * mobileMultiplier : baseSpeed;
        stripe.ispeed = stripe.directionMultiplier * newBase;
        stripe.targetSpeed = window.innerWidth >= breakpoint && stripe.hovered ? 0 : stripe.ispeed;
      });
    };

    function setupStripe(el: Element, directionMultiplier: number) {
      const firstChild = el.firstElementChild as HTMLElement;
      if (!firstChild) return;
      
      const length = firstChild.getBoundingClientRect().height;
      const isMobile = window.innerWidth < breakpoint;
      const dynamicBase = isMobile ? baseSpeed * mobileMultiplier : baseSpeed;
      const ispeed = directionMultiplier * dynamicBase;

      const stripeObj = {
        el: el as HTMLElement,
        length,
        directionMultiplier,
        currentPos: 0,
        speed: 0,
        targetSpeed: ispeed,
        ispeed,
        hovered: false
      };
      stripes.push(stripeObj);

      const onEnter = () => {
        stripeObj.hovered = true;
        if (window.innerWidth >= breakpoint) {
          stripeObj.targetSpeed = 0;
        }
      };
      const onLeave = () => {
        stripeObj.hovered = false;
        if (window.innerWidth >= breakpoint) {
          stripeObj.targetSpeed = stripeObj.ispeed;
        }
      };

      el.addEventListener("mouseenter", onEnter);
      el.addEventListener("mouseleave", onLeave);
      
      return () => {
        el.removeEventListener("mouseenter", onEnter);
        el.removeEventListener("mouseleave", onLeave);
      };
    }

    const cleanupFns: Array<() => void> = [];

    allStripes.forEach((el) => {
      const directionMultiplier = el.classList.contains("is-up") ? -1 : 1;
      const cleanup = setupStripe(el, directionMultiplier);
      if (cleanup) cleanupFns.push(cleanup);
    });

    window.addEventListener("resize", resizeListener);

    function loop() {
      animationFrameId = requestAnimationFrame(loop);
      stripes.forEach((stripe) => {
        stripe.speed += (stripe.targetSpeed - stripe.speed) * 0.05;
        stripe.currentPos += stripe.speed;

        if (stripe.speed < 0 && stripe.currentPos <= -stripe.length) {
          stripe.currentPos = 0;
        } else if (stripe.speed > 0 && stripe.currentPos >= stripe.length) {
          stripe.currentPos = 0;
        }

        stripe.el.style.transform = `translate3d(0, ${stripe.currentPos}px, 0)`;
      });
    }

    loop();
    
    // Allow cleanup to be called via Astro lifecycle if needed later
    (window as any).__cleanupTestimonial = () => {
      cancelAnimationFrame(animationFrameId);
      window.removeEventListener("resize", resizeListener);
      cleanupFns.forEach(fn => fn());
    };
  }

  // Hook into Astro's client-side routing if view transitions are enabled
  document.addEventListener('astro:page-load', () => {
    if ((window as any).__cleanupTestimonial) {
        (window as any).__cleanupTestimonial();
    }
    initTestimonial();
  });
  
  // Run initially
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTestimonial);
  } else {
    initTestimonial();
  }
</script>

