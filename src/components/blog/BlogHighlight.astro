---
import AnimatedArrowIsland from "../ui/AnimatedArrowIsland";
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang, "home");
---

<section class="w-full px-4 xl:px-5 py-4 lg:py-9 border-t border-b border-black">
  <div class="w-full mb-4">
    <img
      src="https://images.unsplash.com/photo-1775840532502-59540d252c54?q=80&w=3540&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D=format&fit=crop"
      alt="Blog Highlight"
      class="w-full h-[35vh] sm:h-[70vh] md:h-[40vh] lg:h-[80vh] object-cover"
      loading="lazy"
    />
  </div>

  <div class="flex flex-row justify-between items-center mb-4 gap-8">
    <span class="text-xs lg:text-lg font-regular tracking-[0.13em] uppercase text-black">
      {t("agenda.label")}
    </span>
    <div class="w-full md:w-[300px] lg:w-[400px] flex justify-end">
      <AnimatedArrowIsland
        client:visible
        text={t("agenda.cta_label")}
        hideBorders={true}
        slideLeft={true}
        textClassName="text-xs lg:text-lg font-normal"
        paddingClassName="py-0 lg:py-[11px]"
      />
    </div>
  </div>

  <div class="flex flex-col gap-4">
    <h2 class="text-4xl md:text-5xl lg:text-[5rem] leading-[1.05] font-medium tracking-tight text-black max-w-[95%] md:max-w-[75%] whitespace-pre-line">
      {t("agenda.title")}
    </h2>
    <p class="text-lg md:text-2xl text-black whitespace-pre-line">
      {t("agenda.desc")}
    </p>
  </div>
</section>
