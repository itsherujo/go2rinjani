---
import { getLangFromUrl, useTranslations } from "../../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang, "blog");
---

<section class="w-full flex flex-col pt-6">
  <div class="px-4 xl:px-5 mb-8 lg:mb-12">
    <h1
      class="text-[2.23rem] leading-[1.05] min-[481px]:text-4xl lg:text-[5.5rem] lg:leading-none font-normal tracking-tight text-foreground max-w-full lg:max-w-[90%] mb-4 lg:mb-6"
    >
      {t("hero.title")}
    </h1>
    <p
      class="text-base min-[481px]:text-lg lg:text-3xl font-light text-foreground max-w-4xl lg:max-w-[95%] leading-snug lg:leading-normal"
    >
      {t("hero.desc")}
    </p>
  </div>
</section>
