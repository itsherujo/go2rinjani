---
import { getLangFromUrl, useTranslations } from "../../../i18n/utils";
import AnimatedArrowIsland from "../../../components/ui/AnimatedArrowIsland";
import { blogImages } from "../data/constants";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang, "blog");
---

<section class="w-full px-4 xl:px-5 py-8">
  <div class="w-full grid lg:grid-cols-2 min-h-[450px] lg:min-h-[600px]">
    {/* Left Image Background */}
    <div class="w-full h-[55vh] lg:h-full bg-gray-100 overflow-hidden">
      <img
        src={blogImages.featured}
        alt={t("featured.title") as string}
        class="w-full h-full object-cover"
      />
    </div>

    {/* Right Content Section bg-brand-pink */}
    <div class="w-full bg-brand-pink px-6 py-8 min-[481px]:px-8 min-[481px]:py-10 lg:px-12 lg:py-16 flex flex-col justify-between">
      <div>
        <h2 class="text-[2rem] leading-[1.05] min-[481px]:text-4xl lg:text-[3.5rem] lg:leading-[1.1] font-medium tracking-tight text-foreground mb-3 min-[481px]:mb-4">
          {t("featured.title")}
        </h2>
        <p class="text-base min-[481px]:text-lg lg:text-3xl font-light text-foreground max-w-full lg:max-w-[95%] leading-snug lg:leading-tight">
          {t("featured.desc")}
        </p>
      </div>

      <div class="mt-8 min-[481px]:mt-12 lg:mt-auto lg:pt-8 w-fit">
        <AnimatedArrowIsland
          client:visible
          text={t("featured.cta_label") as string}
          ariaLabel={`${t("featured.cta_label")}: ${t("featured.title")}`}
          href={lang === 'en' ? '/blog/trekking-smart-on-mount-rinjani-your-complete-preparation-guide' : `/${lang}/blog/trekking-smart-on-mount-rinjani-your-complete-preparation-guide`}
          hideBorders={true}
          textClassName="text-[11px] lg:text-[13px] tracking-widest uppercase font-medium"
          paddingClassName="py-1"
        />
      </div>
    </div>
  </div>
</section>
