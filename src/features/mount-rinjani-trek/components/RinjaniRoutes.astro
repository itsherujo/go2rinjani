---
import { Image } from "astro:assets";
import { useTranslations } from "../../../i18n/utils";
import SectionTitle from "../../../components/ui/Typography/SectionTitle.astro";
import SectionDesc from "../../../components/ui/Typography/SectionDesc.astro";
import Section from "../../../components/ui/Layout/Section.astro";
import AnimatedArrowIsland from "../../../components/ui/AnimatedArrowIsland";

import { rinjaniRouteImages } from "../data/rinjaniImages";

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang, "mount-rinjani-trek");

// Cast the translated array correctly
const routes = t("routes", { returnObjects: true }) as any[];
---

<Section class="pt-12 pb-12">
  {
    routes.map((route: any, idx: number) => {
      const images =
        rinjaniRouteImages[route.id] || rinjaniRouteImages["sembalun-route"];
      const langPrefix = lang !== "en" ? `/${lang}` : "";

      return (
        <div class={idx > 0 ? "mt-12" : ""}>
          {/* Section Header */}
          <div class="w-full flex flex-col mb-6 lg:mb-8">
            <SectionTitle class="mb-2 lg:mb-4">{route.title}</SectionTitle>
            <div class="w-full h-px bg-foreground my-4 lg:my-6" />
            <SectionDesc class="max-w-full! lg:max-w-full! leading-relaxed">
              {route.desc}
            </SectionDesc>
          </div>

          {/* Image Gallery */}
          <div class="w-full mb-4 lg:mb-8">
            <div class="flex flex-row w-[calc(100%+2rem)] min-[481px]:w-full -ml-4 min-[481px]:ml-0 px-4 min-[481px]:px-0 overflow-x-auto min-[481px]:overflow-visible snap-x snap-mandatory scroll-px-4 gap-4 lg:gap-5 [&::-webkit-scrollbar]:hidden [-ms-overflow-style:none] scrollbar-none">
              <div class="shrink-0 min-[481px]:shrink w-[calc(100%-2rem)] min-[481px]:flex-1 min-[481px]:w-auto snap-start min-[481px]:snap-align-none aspect-4/5 min-[481px]:aspect-auto h-auto min-[481px]:h-[50vh] lg:h-[60vh] overflow-hidden bg-gray-200">
                <Image
                  src={images[0]}
                  alt={images[0].alt || `${route.title} view 1`}
                  class="w-full h-full object-cover"
                  widths={[360, 540, 720, images[0].width]}
                  sizes="(max-width: 480px) 440px, (max-width: 768px) 360px, 50vw"
                />
              </div>
              <div class="shrink-0 min-[481px]:shrink w-[calc(100%-2rem)] min-[481px]:flex-1 min-[481px]:w-auto snap-start min-[481px]:snap-align-none aspect-4/5 min-[481px]:aspect-auto h-auto min-[481px]:h-[50vh] lg:h-[60vh] overflow-hidden bg-gray-200">
                <Image
                  src={images[1]}
                  alt={images[1].alt || `${route.title} view 2`}
                  class="w-full h-full object-cover"
                  widths={[360, 540, 720, images[1].width]}
                  sizes="(max-width: 480px) 440px, (max-width: 768px) 360px, 50vw"
                />
              </div>
            </div>
          </div>

          {/* Packages List */}
          <div class="w-full">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
              {route.packages.map((pkg: any) => {
                const toPath =
                  langPrefix +
                  (pkg.cta_url === "/" && langPrefix ? "" : pkg.cta_url);
                return (
                  <div class="bg-gray-100 border border-foreground flex flex-col p-6 min-[481px]:p-8 h-full">
                    <p class="text-sm tracking-wide mb-4">
                      {pkg.duration.replace(" Days ", " Days . ")}
                    </p>
                    <h3 class="font-semibold text-[1.35rem] min-[481px]:text-2xl lg:text-[1.75rem] leading-tight mb-6">
                      {pkg.title}
                    </h3>

                    {/* Highlights */}
                    <div class="flex flex-col mb-10 w-full">
                      <div class="w-full h-px bg-foreground" />
                      {pkg.highlights.map((highlight: string) => (
                        <div class="w-full flex pb-3 pt-3 border-b border-foreground">
                          <span class="mr-2">•</span>
                          <span class="text-sm lg:text-base leading-snug">
                            {highlight}
                          </span>
                        </div>
                      ))}
                    </div>

                    {/* CTA */}
                    <div class="mt-auto w-fit md:w-full min-w-[200px]">
                      <AnimatedArrowIsland
                        client:visible
                        text={pkg.cta_label}
                        href={toPath}
                        hideBorders={true}
                        textClassName="text-[11px] lg:text-[13px] tracking-[0.15em] uppercase font-semibold"
                        paddingClassName="py-1"
                      />
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        </div>
      );
    })
  }
</Section>
