---
import { Image } from "astro:assets";
import { useTranslations } from "../../../i18n/utils";
import PageHeader from "../../../components/ui/Layout/PageHeader.astro";
import HeroTitle from "../../../components/ui/Typography/HeroTitle.astro";
import HeroDesc from "../../../components/ui/Typography/HeroDesc.astro";
import { rinjaniHeroImage as coverImage } from "../data/rinjaniImages";

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang, "mount-rinjani-trek");
---

<div class="w-full bg-background flex flex-col pb-8">
  {/* Title */}
  <PageHeader>
    <HeroTitle>{t("hero.title")}</HeroTitle>
  </PageHeader>

  {/* Image Container */}
  <div class="w-full px-4 xl:px-5 py-4 min-[481px]:py-6">
    <div
      class="w-full h-[40vh] min-[481px]:h-[60vh] lg:h-[70vh] bg-gray-100 overflow-hidden relative"
    >
      <Image
        src={coverImage}
        class="w-full h-full object-cover"
        alt={coverImage.alt}
        loading="eager"
        fetchpriority="high"
        widths={[360, 540, 720, 1080, coverImage.width]}
        sizes="(max-width: 480px) 440px, (max-width: 768px) 720px, 100vw"
      />
    </div>
  </div>

  {/* Description */}
  <div class="w-full px-4 xl:px-5">
    <HeroDesc class="max-w-full! lg:max-w-full! leading-relaxed">
      {t("hero.desc")}
    </HeroDesc>
  </div>
</div>
