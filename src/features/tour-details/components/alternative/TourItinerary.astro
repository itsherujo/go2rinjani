---
import { useTranslations } from "../../../../i18n/utils";
import Section from "../../../../components/ui/Layout/Section.astro";
import SectionTitle from "../../../../components/ui/Typography/SectionTitle.astro";
import SectionDesc from "../../../../components/ui/Typography/SectionDesc.astro";

interface Props {
  lang: string;
  slug: string;
}

const { lang, slug } = Astro.props;
const t = useTranslations(lang, `tour-details/${slug}`);

const itinerary = t("itinerary.days", { returnObjects: true }) as any[];
---

{itinerary && itinerary.length > 0 && (
  <Section>
    <div class="mb-8 lg:mb-12">
      <SectionTitle>{t("itinerary.section_title")}</SectionTitle>
      <SectionDesc>{t("itinerary.intro")}</SectionDesc>
    </div>

    <div class="w-full border-t border-black pt-8">
      <div class="w-full bg-stampol-red-light">
        <div class="bg-stampol-red-dark w-full p-4 lg:p-6 text-black border min-[481px]:border border-black">
          <h3 class="text-3xl md:text-4xl font-normal tracking-tight mb-8">
            {t("itinerary.schedule_label", { defaultValue: "Itinerary Schedule" })}
          </h3>
          <div class="flex flex-col gap-12">
            {itinerary.map((day: any) => (
              <div class="border-b border-black pb-8 last:border-0 last:pb-0">
                <span class="block text-sm font-medium tracking-widest uppercase mb-3">
                  {day.day}
                </span>
                <span class="block text-2xl md:text-3xl font-medium mb-4">
                  {day.title}
                </span>
                <p class="block text-base md:text-lg mb-6 leading-relaxed max-w-4xl">
                  {day.desc}
                </p>
                <ul class="list-disc pl-5 space-y-2 max-w-3xl">
                  {day.highlights?.map((hl: string) => (
                    <li class="text-sm md:text-base">
                      {hl}
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </Section>
)}
