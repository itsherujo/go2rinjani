---
import { useTranslations } from "../../../../i18n/utils";
import SectionTitle from "../../../../components/ui/Typography/SectionTitle.astro";
import SectionDesc from "../../../../components/ui/Typography/SectionDesc.astro";

interface Props {
  lang: string;
  slug: string;
}

const { lang, slug } = Astro.props;
const t = useTranslations(lang, `tour-details/${slug}`);
---

<section class="w-full px-4 xl:px-5">
  <div class="w-full relative flex flex-col">
    <SectionTitle>{t("intro.title")}</SectionTitle>
    <SectionDesc>{t("intro.desc")}</SectionDesc>
  </div>
</section>
