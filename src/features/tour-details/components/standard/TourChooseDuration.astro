---
import { useTranslations } from "../../../../i18n/utils";
import SectionTitle from "../../../../components/ui/Typography/SectionTitle.astro";

interface Props {
  lang: string;
  slug: string;
}

import { standardHeroImageMap } from "./data/standardImages";
import { senaruHeroImageMap } from "./data/senaruImages";

const allHeroImages = { ...standardHeroImageMap, ...senaruHeroImageMap };

const { lang, slug } = Astro.props;
const t = useTranslations(lang, `tour-details/${slug}`);

const durations = t("choose_duration.items", { returnObjects: true }) as any[];
---

{
  durations && durations.length > 0 && (
    <section class="w-full px-4 xl:px-5 bg-background">
      <div class="mb-4">
        <SectionTitle>{t("choose_duration.section_title")}</SectionTitle>
      </div>

      <div class="w-full h-px bg-black mb-6 md:mb-8" />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {durations.map((item: any, idx: number) => {
          const isLastOdd = idx === 2 && durations.length === 3;
          const langPrefix = lang !== "en" ? `/${lang}` : "";
          const toPath =
            langPrefix +
            (item.cta_url === "/" && langPrefix ? "" : item.cta_url);
          const isActive = toPath.includes(slug);
          const itemSlug = item.cta_url.split('/').pop() || "";
          const imageObj = allHeroImages[itemSlug];

          return (
            <div
              class={`relative overflow-hidden group ${isLastOdd ? "md:col-span-2" : ""}`}
            >
              <div class="absolute inset-0 bg-black/20 z-10" />
              <img
                src={imageObj?.src || ""}
                width={imageObj?.width || 800}
                height={imageObj?.height || 600}
                alt={item.duration}
                class="absolute inset-0 w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-700 ease-out z-0"
                referrerpolicy="no-referrer"
              />
              <div class="relative z-20 flex flex-col items-center justify-center p-8 md:p-12 text-center text-white h-full min-h-[300px]">
                <h3 class="text-3xl md:text-5xl font-medium mb-4 drop-shadow-md">
                  {item.duration}
                </h3>
                <p class="text-base md:text-lg mb-8 max-w-xl text-white/90 drop-shadow-md leading-relaxed">
                  {item.best_for}
                </p>
                <a
                  href={toPath}
                  class="bg-white text-black px-4 py-2.5 text-[15px] font-medium hover:bg-gray-100 transition-colors shadow-lg"
                >
                  {isActive
                    ? item.cta_label
                    : t("choose_duration.read_more_label", {
                        defaultValue: "Read more",
                      })}
                </a>
              </div>
            </div>
          );
        })}
      </div>
    </section>
  )
}
