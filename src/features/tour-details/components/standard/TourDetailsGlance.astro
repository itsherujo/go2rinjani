---
import { useTranslations } from "../../../../i18n/utils";
import SectionTitle from "../../../../components/ui/Typography/SectionTitle.astro";
import SectionDesc from "../../../../components/ui/Typography/SectionDesc.astro";

interface Props {
  lang: string;
  slug: string;
}

const { lang, slug } = Astro.props;
const t = useTranslations(lang, `tour-details/${slug}`);

const details = t("trek_details.details", { returnObjects: true }) as any[];
---

{
  details && details.length > 0 && (
    <section class="w-full px-4 xl:px-5 bg-background">
      <div class="mb-4">
        <SectionTitle>{t("trek_details.section_title")}</SectionTitle>
        <SectionDesc class="lg:max-w-[75%]!">
          {t("trek_details.intro")}
        </SectionDesc>
      </div>

      <div class="w-full border-t border-foreground pt-8">
        <div class="w-full border border-foreground p-4 lg:p-6 bg-stampol-blue">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-6">
            {details.map((detail: any) => (
              <div class="flex flex-col border-b border-foreground/40 pb-1.5">
                <span class="text-sm font-medium uppercase tracking-widest text-foreground/70 mb-1">
                  {detail.label}
                </span>
                <span class="text-lg md:text-xl font-medium text-foreground">
                  {detail.value}
                </span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  )
}
