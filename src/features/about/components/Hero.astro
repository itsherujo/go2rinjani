---
import { Image } from 'astro:assets';
import { getLangFromUrl, useTranslations } from '../../../i18n/utils';
import { aboutImages } from '../data/constants';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang, "about");
---

<section class="w-full flex flex-col">
  <header class="w-full px-4 xl:px-5 pt-6 pb-4 mb-4 lg:mb-8">
    <h1 class="text-[2.23rem] leading-[1.05] min-[481px]:text-4xl lg:text-[5.5rem] lg:leading-none font-normal tracking-tight text-foreground max-w-full lg:max-w-[90%] mb-4 lg:mb-6">
      {t("hero.title")}
    </h1>
    <p class="text-base min-[481px]:text-lg lg:text-3xl font-light text-foreground max-w-4xl lg:max-w-[95%] leading-snug lg:leading-normal">
      {t("hero.desc")}
    </p>
  </header>
  <div class="w-full relative">
    <Image
      src={aboutImages.hero.src}
      alt={aboutImages.hero.alt}
      class="w-full h-[40vh] min-[481px]:h-[60vh] lg:h-[80vh] object-cover px-4 xl:px-5"
      loading="eager"
      fetchpriority="high"
      widths={[360, 540, 720, 1080, 1440, aboutImages.hero.src.width]}
      sizes="(max-width: 480px) 440px, (max-width: 768px) 720px, 100vw"
    />
  </div>
</section>
