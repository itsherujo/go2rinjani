---
import { Image } from 'astro:assets';
import { getLangFromUrl, useTranslations } from '../../../i18n/utils';
import { aboutImages } from '../data/constants';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang, "about");
---

<section class="w-full px-4 xl:px-5 py-8 lg:py-16">
  <div class="mb-8 lg:mb-12">
    <h2 class="text-[2rem] leading-[1.05] min-[481px]:text-4xl lg:text-[3.5rem] lg:leading-[1.1] font-medium tracking-tight text-foreground mb-3 min-[481px]:mb-4">
      {t("closing.title")}
    </h2>
    <p class="text-base min-[481px]:text-lg lg:text-3xl font-light text-foreground max-w-full lg:max-w-[95%] leading-snug lg:leading-tight">
      {t("closing.desc")}
    </p>
  </div>
  <div class="w-full relative px-0">
    <Image
      src={aboutImages.closing.src}
      alt={aboutImages.closing.alt}
      class="w-full h-[40vh] min-[481px]:h-[60vh] lg:h-[80vh] object-cover"
      widths={[360, 540, 720, 1080, 1440, aboutImages.closing.src.width]}
      sizes="(max-width: 480px) 440px, (max-width: 768px) 720px, 100vw"
    />
  </div>
</section>
