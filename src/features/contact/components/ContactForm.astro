---
import { getLangFromUrl, useTranslations } from "../../../i18n/utils";
import Section from "../../../components/ui/Layout/Section.astro";
import ContactFormIsland from "../islands/ContactFormIsland.tsx";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang, "contact");

const translations: Record<string, string> = {
  "form.header": t("form.header") as string,
  "form.description": t("form.description") as string,
  "form.yourDetails": t("form.yourDetails") as string,
  "form.firstName": t("form.firstName") as string,
  "form.firstNamePlaceholder": t("form.firstNamePlaceholder") as string,
  "form.lastName": t("form.lastName") as string,
  "form.lastNamePlaceholder": t("form.lastNamePlaceholder") as string,
  "form.phone": t("form.phone") as string,
  "form.phonePlaceholder": t("form.phonePlaceholder") as string,
  "form.email": t("form.email") as string,
  "form.emailPlaceholder": t("form.emailPlaceholder") as string,
  "form.message": t("form.message") as string,
  "form.messagePlaceholder": t("form.messagePlaceholder") as string,
  "form.termsAgree": t("form.termsAgree") as string,
  "form.formComplete": t("form.formComplete") as string,
  "form.submit": t("form.submit") as string,
  "form.success": t("form.success", { defaultValue: "Thank you! Your message has been sent. We'll respond within 24 hours." }) as string,
  "form.errorRequired": t("form.errorRequired", { defaultValue: "Please fill in all required fields." }) as string,
  "form.errorTerms": t("form.errorTerms", { defaultValue: "You must accept the terms to submit." }) as string,
  "form.errorNetwork": t("form.errorNetwork", { defaultValue: "Network error. Please check your connection and try again." }) as string,
  "form.errorGeneric": t("form.errorGeneric", { defaultValue: "Something went wrong. Please try again." }) as string,
  "form.sending": t("form.sending", { defaultValue: "Sending..." }) as string,
};
---

<Section class="pt-6 pb-12">
  <ContactFormIsland client:load translations={translations} locale={lang} />
</Section>
