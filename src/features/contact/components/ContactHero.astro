---
import { getLangFromUrl, useTranslations } from "../../../i18n/utils";
import PageHeader from "../../../components/ui/Layout/PageHeader.astro";
import HeroTitle from "../../../components/ui/Typography/HeroTitle.astro";
import Section from "../../../components/ui/Layout/Section.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang, "contact");
---

<Section class="py-4 xl:px-0" id="contact-hero">
  <div class="animate-fade-in-up">
    <PageHeader class="px-0! py-0!">
      <HeroTitle class="font-bold uppercase max-w-5xl">{t("title")}</HeroTitle>
    </PageHeader>
  </div>
</Section>

<style>
  .animate-fade-in-up {
    animation: fadeInUp 0.6s ease-out forwards;
  }
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
