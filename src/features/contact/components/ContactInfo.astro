---
import { getLangFromUrl, useTranslations } from "../../../i18n/utils";
import Section from "../../../components/ui/Layout/Section.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang, "contact");

const days = Object.keys(t("days", { returnObjects: true }) || {}) as string[];
---

<Section class="py-4">
  <div class="flex flex-col max-w-xl animate-fade-in-up-delay">
    <div class="text-base md:text-xl mb-12 leading-snug">
      {t("address")}
    </div>

    <div class="mb-12">
      <h3 class="text-xl md:text-2xl font-medium mb-5">{t("office.title")}</h3>
      <div class="flex flex-col gap-1.5">
        {days.map((day) => (
          <div class="flex text-base md:text-lg">
            <span class="font-medium w-40 md:w-48">{t(`days.${day}`)}</span>
            <span class="text-gray-900">{t(`office.schedule.${day}`)}</span>
          </div>
        ))}
      </div>
    </div>

    <div>
      <h3 class="text-xl md:text-2xl font-medium mb-5">{t("online.title")}</h3>
      <div class="flex flex-col gap-1.5">
        {days.map((day) => (
          <div class="flex text-base md:text-lg">
            <span class="font-medium w-40 md:w-48">{t(`days.${day}`)}</span>
            <span class="text-gray-900">{t(`online.schedule.${day}`)}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</Section>

<style>
  .animate-fade-in-up-delay {
    opacity: 0;
    animation: fadeInUp 0.6s ease-out 0.2s forwards;
  }
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
