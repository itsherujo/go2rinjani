---
import SectionTitle from "../../../components/ui/Typography/SectionTitle.astro";
import SectionDesc from "../../../components/ui/Typography/SectionDesc.astro";
import { getLangFromUrl, useTranslations } from "../../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang, "payment-information");
---

<aside class="w-full md:w-64 lg:w-72 shrink-0 flex flex-col gap-6">
  <div>
    <h1
      class="text-[2rem] leading-[1.05] min-[481px]:text-4xl lg:text-[3.5rem] lg:leading-[1.1] font-medium tracking-tight text-foreground mb-2 lg:mb-2 md:text-4xl min-[481px]:text-4xl lg:text-[3rem] lg:leading-[1.1] max-w-min md:max-w-none wrap-break-word hyphens-auto"
    >
      {t("title")}
    </h1>
    <SectionDesc
      class="text-sm md:text-base lg:text-lg text-foreground/70 leading-relaxed md:mb-6"
    >
      {t("subtitle")}
    </SectionDesc>
  </div>

  <div class="hidden md:flex flex-col gap-4">
    <!-- Secure & Trusted -->
    <div class="flex items-start gap-3">
      <div
        class="w-8 h-8 rounded-none bg-background border border-foreground flex items-center justify-center text-foreground shrink-0"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path
            d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"
          ></path><path d="m9 12 2 2 4-4"></path></svg
        >
      </div>
      <div>
        <strong class="block text-xs font-medium mb-0.5"
          >{t("trust.secure.title")}</strong
        >
        <span class="text-[11px] text-foreground/70 leading-relaxed"
          >{t("trust.secure.desc")}</span
        >
      </div>
    </div>
    <!-- Need Help? -->
    <div class="flex items-start gap-3">
      <div
        class="w-8 h-8 rounded-none bg-background border border-foreground flex items-center justify-center text-foreground shrink-0"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path d="M3 18v-6a9 9 0 0 1 18 0v6"></path><path
            d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"
          ></path></svg
        >
      </div>
      <div>
        <strong class="block text-xs font-medium mb-0.5"
          >{t("trust.help.title")}</strong
        >
        <span class="text-[11px] text-foreground/70 leading-relaxed"
          >{t("trust.help.desc")}</span
        >
      </div>
    </div>
  </div>

  <hr class="hidden md:block border-foreground/20 my-2" />

  <a
    href="mailto:go2rinjani@gmail.com"
    class="hidden md:flex items-center gap-1.5 text-xs text-foreground hover:text-foreground/80 transition-colors"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      ><rect width="20" height="16" x="2" y="4" rx="2"></rect><path
        d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg
    >
    go2rinjani@gmail.com
  </a>

  <p
    class="hidden text-[11px] text-foreground/70 text-right content-end flex-1 max-w-[200px] ml-auto"
  >
    {t("tabletSub")}
  </p>
</aside>
