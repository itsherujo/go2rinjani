---
import H3Title from "../../../components/ui/Typography/H3Title.astro";
import { getLangFromUrl, useTranslations } from "../../../i18n/utils";
import paypalIcon from "../../../assets/svg/payment-information/paypal.svg";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang, "payment-information");
---

<div data-payment-card="paypal" class="hidden md:block bg-background border border-foreground rounded-none shadow-sm overflow-hidden">
  <!-- Header -->
  <div class="flex items-center gap-3 p-4 border-b border-foreground">
    <div class="flex items-center justify-center shrink-0">
      <img src={paypalIcon.src} alt="PayPal" class="h-6 md:h-8 object-contain" />
    </div>
    <div>
      <H3Title class="text-base md:text-lg tracking-tight mb-0.5">{t("methods.paypal")}</H3Title>
      <p class="text-[11px] text-foreground/70 mt-0.5">{t("paypal.desc")}</p>
    </div>
    <div class="ml-auto text-[10px] font-medium text-foreground bg-background border border-foreground px-2.5 py-1 rounded-none shrink-0">
      {t("paypal.optional")}
    </div>
  </div>

  <!-- Content -->
  <div class="p-4 md:px-5 md:py-4">
    <div class="flex flex-col md:flex-row md:items-start justify-between gap-4">
      <div class="flex flex-col gap-2.5 max-w-sm">
        <div class="flex items-start gap-2.5 text-[11px] md:text-xs text-foreground/80">
          <svg class="w-4 h-4 text-foreground/50 mt-px shrink-0" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>
          <span>{t("paypal.fee")}</span>
        </div>
        <div class="flex items-start gap-2.5 text-[11px] md:text-xs text-foreground/80">
          <svg class="w-4 h-4 text-foreground/50 mt-px shrink-0" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/></svg>
          <span>{t("paypal.invoiceInfo")}</span>
        </div>
        <div class="flex items-start gap-2.5 text-[11px] md:text-xs text-foreground/80">
          <svg class="w-4 h-4 text-foreground/50 mt-px shrink-0" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
          <span>{t("paypal.sendEmail")}</span>
        </div>
      </div>

      <a
        href="mailto:go2rinjani@gmail.com?subject=PayPal%20Invoice%20Request"
        class="bg-foreground border border-foreground text-background hover:bg-foreground/90 text-xs md:text-sm font-medium px-4 py-2.5 md:py-2 rounded-none transition-colors flex items-center justify-center gap-2 shrink-0 w-full md:w-auto"
        aria-label={t("paypal.btnRequest") as string}
      >
        <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        {t("paypal.btnRequest")}
      </a>
    </div>
  </div>
</div>
