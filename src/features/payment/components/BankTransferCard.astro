---
import H3Title from "../../../components/ui/Typography/H3Title.astro";
import { getLangFromUrl, useTranslations } from "../../../i18n/utils";
import permataIcon from "../../../assets/svg/payment-information/permata_bank.svg";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang, "payment-information");
---

<div data-payment-card="bank" class="bg-background border border-foreground shadow-sm overflow-hidden rounded-none">
  <!-- Header -->
  <div class="flex items-center gap-3 md:gap-4 p-4 md:px-5 md:py-4 border-b border-foreground">
    <div class="flex items-center justify-center shrink-0">
      <img src={permataIcon.src} alt="Permata Bank" class="h-6 md:h-8 object-contain" />
    </div>
    <div>
      <H3Title class="text-base md:text-lg tracking-tight mb-0.5">{t("methods.bank")}</H3Title>
      <p class="text-[11px] md:text-xs text-foreground/70 mt-0.5">{t("bankTransfer.desc")}</p>
    </div>
    <div class="ml-auto text-[10px] md:text-xs font-medium text-text-inverse bg-brand-dark border border-black px-2.5 py-1 flex items-center gap-1 shrink-0 rounded-none">
      {t("bankTransfer.recommended")}
    </div>
  </div>

  <!-- Details -->
  <div class="p-4 md:px-5 md:py-4">
    <div class="flex flex-col">
      <!-- Bank Name -->
      <div class="flex items-center py-2.5 border-b border-foreground/20 group">
        <span class="text-xs text-foreground/80 w-28 md:w-36 shrink-0">{t("bankTransfer.bankName")}</span>
        <span class="text-xs md:text-sm font-medium tracking-tight flex-1">PT. Bank Permata Tbk</span>
      </div>
      <!-- Account Number -->
      <div class="flex items-center py-2.5 border-b border-foreground/20 group">
        <span class="text-xs text-foreground/80 w-28 md:w-36 shrink-0">{t("bankTransfer.accountNumber")}</span>
        <span class="font-mono text-xs md:text-sm tracking-wider font-medium flex-1">4155000002</span>
        <button
          data-copy="4155000002"
          class="w-7 h-7 rounded-none flex items-center justify-center transition-all shrink-0 bg-background text-foreground hover:bg-foreground hover:text-background border border-foreground"
          title={t("bankTransfer.copyAccountNumber") as string}
          aria-label={t("bankTransfer.copyAccountNumber") as string}
        >
          <!-- Copy icon -->
          <svg class="w-3.5 h-3.5 copy-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
          <!-- Check icon (hidden) -->
          <svg class="w-3.5 h-3.5 check-icon hidden" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
        </button>
      </div>
      <!-- Account Holder -->
      <div class="flex items-center py-2.5 border-b border-foreground/20 group">
        <span class="text-xs text-foreground/80 w-28 md:w-36 shrink-0">{t("bankTransfer.accountHolder")}</span>
        <span class="text-xs md:text-sm font-medium tracking-tight flex-1">Heru Fahrizal</span>
      </div>
      <!-- SWIFT Code -->
      <div class="flex items-center py-2.5 border-b border-foreground/20 group">
        <span class="text-xs text-foreground/80 w-28 md:w-36 shrink-0">{t("bankTransfer.swiftCode")}</span>
        <span class="font-mono text-xs md:text-sm tracking-wider font-medium flex-1">BBBAIDJA</span>
        <button
          data-copy="BBBAIDJA"
          class="w-7 h-7 rounded-none flex items-center justify-center transition-all shrink-0 bg-background text-foreground hover:bg-foreground hover:text-background border border-foreground"
          title={t("bankTransfer.copySwiftCode") as string}
          aria-label={t("bankTransfer.copySwiftCode") as string}
        >
          <svg class="w-3.5 h-3.5 copy-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
          <svg class="w-3.5 h-3.5 check-icon hidden" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
        </button>
      </div>
      <!-- Bank Address -->
      <div class="flex items-start py-2.5 group">
        <span class="text-xs text-foreground/80 w-28 md:w-36 shrink-0 pt-0.5">{t("bankTransfer.bankAddress")}</span>
        <span class="text-[11px] md:text-xs leading-relaxed text-foreground flex-1">
          Jl. Pariwisata Senaru, Dusun Tumpang Sari,<br />Dasan Lendang Gocek, Bayan, 83354
        </span>
        <button
          data-copy="Jl. Pariwisata Senaru, Dusun Tumpang Sari, Dasan Lendang Gocek, Bayan, 83354"
          class="w-7 h-7 rounded-none flex items-center justify-center transition-all shrink-0 mt-0.5 bg-background text-foreground hover:bg-foreground hover:text-background border border-foreground"
          title={t("bankTransfer.copyBankAddress") as string}
          aria-label={t("bankTransfer.copyBankAddress") as string}
        >
          <svg class="w-3.5 h-3.5 copy-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
          <svg class="w-3.5 h-3.5 check-icon hidden" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Notice Footer -->
  <div class="bg-brand-dark px-4 md:px-5 py-3 flex items-start gap-2.5 text-text-inverse border-t border-foreground">
    <svg class="w-4 h-4 shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
    <p class="text-[11px] md:text-xs leading-relaxed">
      Please include your <strong class="font-semibold mx-1">invoice number</strong> in the payment reference.
    </p>
  </div>
</div>
