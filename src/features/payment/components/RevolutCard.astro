---
import H3Title from "../../../components/ui/Typography/H3Title.astro";
import { getLangFromUrl, useTranslations } from "../../../i18n/utils";
import revolutIcon from "../../../assets/svg/payment-information/revolut.svg";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang, "payment-information");
---

<div data-payment-card="revolut" class="hidden md:flex flex-col bg-background border border-foreground rounded-none shadow-sm overflow-hidden">
  <!-- Header -->
  <div class="flex items-center gap-3 p-4 border-b border-foreground">
    <div class="flex items-center justify-center shrink-0">
      <img src={revolutIcon.src} alt="Revolut" class="h-6 md:h-8 object-contain" />
    </div>
    <div>
      <H3Title class="text-base md:text-lg tracking-tight mb-0.5">{t("methods.revolut")}</H3Title>
      <p class="text-[11px] text-foreground/70 mt-0.5">{t("revolut.desc")}</p>
    </div>
  </div>

  <!-- Features -->
  <div class="p-4 flex-1 flex flex-col justify-between gap-4">
    <div class="grid grid-cols-3 gap-2">
      <div class="flex flex-col items-center gap-1.5 bg-background border border-foreground/20 rounded-none px-1 py-2.5 text-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-foreground"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
        <span class="text-[9px] sm:text-[10px] text-foreground/70 leading-tight">{t("revolut.international")}</span>
      </div>
      <div class="flex flex-col items-center gap-1.5 bg-background border border-foreground/20 rounded-none px-1 py-2.5 text-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-foreground"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
        <span class="text-[9px] sm:text-[10px] text-foreground/70 leading-tight">{t("revolut.multicurency")}</span>
      </div>
      <div class="flex flex-col items-center gap-1.5 bg-background border border-foreground/20 rounded-none px-1 py-2.5 text-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-foreground"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        <span class="text-[9px] sm:text-[10px] text-foreground/70 leading-tight">{t("revolut.secure")}</span>
      </div>
    </div>

    <!-- Notice -->
    <div class="flex items-start gap-2 bg-background border border-foreground/20 rounded-none px-3 py-2.5 text-foreground/80 text-[11px]">
      <svg class="w-3.5 h-3.5 shrink-0 mt-0.5 text-foreground/60" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
      {t("revolut.notice")}
    </div>
  </div>
</div>
